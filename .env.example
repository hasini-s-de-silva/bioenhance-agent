# ---------------------------------------------------------------------------
# BioEnhance Agent configuration. Copy to .env and edit.
# .env is gitignored and must never be committed.
# ---------------------------------------------------------------------------

# Reasoning backend: ollama | anthropic | rulebased | auto
#
#   ollama     FREE. A local model, no API key, no account, no billing.
#              This is what the published evaluation uses, so the results are
#              reproducible at zero cost. Setup:
#                  brew install ollama
#                  ollama pull qwen2.5:7b
#   anthropic  A hosted LLM. Needs ANTHROPIC_API_KEY *and* purchased credit.
#   rulebased  Deterministic, no LLM at all. Used by the test suite.
#   auto       anthropic if a key is present, else rulebased.
BIOENHANCE_BACKEND=ollama

# --- Local model (free) ----------------------------------------------------
BIOENHANCE_OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_HOST=http://localhost:11434
# BIOENHANCE_OLLAMA_TIMEOUT=300

# --- Hosted model (optional, costs money) ----------------------------------
# A key alone is not enough; the account also needs credit.
# ANTHROPIC_API_KEY=sk-ant-...
# BIOENHANCE_MODEL=claude-sonnet-5

# --- Retrieval -------------------------------------------------------------
# auto | dense | tfidf
BIOENHANCE_RETRIEVER=auto
