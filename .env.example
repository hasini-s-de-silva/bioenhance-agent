# Anthropic API key. Without it the app falls back to the deterministic
# rule-based backend, which is NOT an LLM and is labelled as such in the UI.
ANTHROPIC_API_KEY=sk-ant-...

# Model to use for the LLM backend.
BIOENHANCE_MODEL=claude-sonnet-5

# Retriever backend: auto | dense | tfidf
#   auto  - try sentence-transformers + FAISS, fall back to TF-IDF
#   dense - force sentence-transformers (requires model download)
#   tfidf - force the sparse fallback (no download; used by CI)
BIOENHANCE_RETRIEVER=auto
